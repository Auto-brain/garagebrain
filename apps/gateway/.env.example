DATABASE_URL=postgresql://platform:your-password@localhost:5432/garagebrain
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
GATEWAY_PORT=4000
# Адрес бэкенда GarageBrain API — шлюз проксирует чат и загрузку фото туда.
BACKEND_URL=http://localhost:3002
# ДОЛЖЕН совпадать с JWT_SECRET бэкенда: шлюз подписывает им сервисные токены
# (единый JWT экосистемы), которые принимает middleware.Auth бэкенда.
JWT_SECRET=change-this-to-random-32-char-string
