OPENROUTER_API_KEY=sk-or-...
OPENROUTER_SITE_URL=https://garagebrain.yourdomain.com
# Основная модель чата. По умолчанию anthropic/claude-haiku-4-5.
# На время тестирования можно указать бесплатную, напр. openai/gpt-oss-20b:free.
# CLAUDE_MODEL=anthropic/claude-haiku-4-5
DATABASE_URL=postgresql://platform:your-password@localhost:5432/garagebrain
JWT_SECRET=change-this-to-random-32-char-string
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
PORT=3002
# Локальное хранилище фото чеков (MVP без S3). Для локальной разработки
# подойдёт ./uploads; в production — /var/www/garagebrain/uploads.
UPLOAD_DIR=./uploads
UPLOAD_PUBLIC_URL=/uploads
# Источник списка бесплатных моделей для фолбэка при 402 (нехватка баланса).
# По умолчанию https://shir-man.com/api/free-llm/top-models — переопределять не нужно.
# FREE_MODELS_URL=https://shir-man.com/api/free-llm/top-models
