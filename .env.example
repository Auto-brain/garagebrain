# ──────────────────────────────────────────────
# GarageBrain Platform — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://platform:your-password@localhost:5432/garagebrain

# ── GarageBrain API (:3002) ──────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_SITE_URL=https://garagebrain.yourdomain.com
JWT_SECRET=change-this-to-random-32-char-string
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
PORT=3002
# Локальное хранилище фото чеков (MVP без S3). В production совпадает с
# nginx location /uploads (alias /var/www/garagebrain/uploads/).
UPLOAD_DIR=/var/www/garagebrain/uploads
UPLOAD_PUBLIC_URL=/uploads

# ── Gateway / Telegram Bot (:4000) ──────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather
GATEWAY_PORT=4000

# ── Domain (for deploy script) ──────────────
DOMAIN=yourdomain.com
